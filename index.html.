// SOUND ENGINE — synthesised woodblock + compressor + vibration
// ══════════════════════════════════════════════
let soundEnabled=localStorage.getItem(SK)!=='off';
let audioCtx=null;
function getAudioCtx(){
  if(!audioCtx){try{audioCtx=new(window.AudioContext||window.webkitAudioContext)();}catch(e){}}
  return audioCtx;
}
function ensureCtx(){
  const ctx=getAudioCtx();
  if(ctx&&ctx.state==='suspended')ctx.resume();
  return ctx;
}

// Synthesised woodblock: layered oscillators + noise burst + compressor
function playTick(isLast=false,isActive=false){
  if(!soundEnabled)return;
  const ctx=ensureCtx();if(!ctx)return;
  const now=ctx.currentTime;
  const comp=ctx.createDynamicsCompressor();
  comp.threshold.value=-12;comp.knee.value=6;comp.ratio.value=4;
  comp.attack.value=0.001;comp.release.value=0.1;
  comp.connect(ctx.destination);

  if(isActive){
    // Soft metronome blip for active set — unobtrusive
    const o=ctx.createOscillator(),g=ctx.createGain();
    o.connect(g);g.connect(comp);
    o.type='triangle';o.frequency.value=880;
    g.gain.setValueAtTime(0,now);
    g.gain.linearRampToValueAtTime(0.06,now+0.003);
    g.gain.exponentialRampToValueAtTime(0.001,now+0.05);
    o.start(now);o.stop(now+0.06);
    if(navigator.vibrate)navigator.vibrate(15);
    return;
  }

  // Woodblock body — two detuned sine waves for thickness
  [400,320].forEach((freq,i)=>{
    const o=ctx.createOscillator(),g=ctx.createGain(),f=ctx.createBiquadFilter();
    o.type='sine';o.frequency.value=isLast?freq*2:freq;
    f.type='bandpass';f.frequency.value=isLast?freq*2:freq;f.Q.value=2;
    o.connect(f);f.connect(g);g.connect(comp);
    g.gain.setValueAtTime(0,now);
    g.gain.linearRampToValueAtTime(isLast?0.28:0.18,now+0.003);
    g.gain.exponentialRampToValueAtTime(0.001,now+(isLast?0.12:0.09));
    o.start(now);o.stop(now+0.15);
  });

  // Transient click — noise burst shaped with fast attack
  const bufLen=ctx.sampleRate*0.04;
  const buf=ctx.createBuffer(1,bufLen,ctx.sampleRate);
  const data=buf.getChannelData(0);
  for(let i=0;i<bufLen;i++)data[i]=(Math.random()*2-1)*Math.pow(1-i/bufLen,4);
  const noise=ctx.createBufferSource(),ng=ctx.createGain();
  const nf=ctx.createBiquadFilter();
  nf.type='highpass';nf.frequency.value=1200;
  noise.buffer=buf;noise.connect(nf);nf.connect(ng);ng.connect(comp);
  ng.gain.setValueAtTime(isLast?0.5:0.35,now);
  ng.gain.exponentialRampToValueAtTime(0.001,now+0.04);
  noise.start(now);noise.stop(now+0.05);

  // Haptic
  if(navigator.vibrate)navigator.vibrate(isLast?[20,10,20]:20);
}

// Tri-tone completion fanfare
function playDone(){
  if(!soundEnabled)return;
  const ctx=ensureCtx();if(!ctx)return;
  const comp=ctx.createDynamicsCompressor();
  comp.threshold.value=-6;comp.ratio.value=3;comp.connect(ctx.destination);
  [[523,0],[659,0.18],[784,0.36],[1047,0.55]].forEach(([freq,delay])=>{
    const o=ctx.createOscillator(),g=ctx.createGain();
    o.connect(g);g.connect(comp);
    o.type='triangle';o.frequency.value=freq;
    const t=ctx.currentTime+delay;
    g.gain.setValueAtTime(0,t);
    g.gain.linearRampToValueAtTime(0.22,t+0.01);
    g.gain.setValueAtTime(0.22,t+0.15);
    g.gain.exponentialRampToValueAtTime(0.001,t+0.4);
    o.start(t);o.stop(t+0.45);
  });
  if(navigator.vibrate)navigator.vibrate([30,50,30,50,60]);
}

// Three fast beeps — set complete signal
function playSetDone(){
  if(!soundEnabled)return;
  const ctx=ensureCtx();if(!ctx)return;
  [0,0.12,0.24].forEach((delay,i)=>{
    const o=ctx.createOscillator(),g=ctx.createGain();
    o.connect(g);g.connect(ctx.destination);
    o.type='sine';o.frequency.value=880+(i*110);
    const t=ctx.currentTime+delay;
    g.gain.setValueAtTime(0,t);
    g.gain.linearRampToValueAtTime(0.15,t+0.005);
    g.gain.exponentialRampToValueAtTime(0.001,t+0.1);
    o.start(t);o.stop(t+0.12);
  });
  if(navigator.vibrate)navigator.vibrate([25,30,25]);
}

