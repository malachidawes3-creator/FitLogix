function saveReminder(){
const time=document.getElementById(‘reminder-time’)?.value||‘07:00’;
localStorage.setItem(‘wl_reminder’,time);
localStorage.setItem(‘wl_reminder_days’,JSON.stringify(_reminderDays));
document.getElementById(‘reminder-overlay’)?.remove();
// Schedule browser notification if supported
if(‘Notification’ in window && Notification.permission===‘default’){
Notification.requestPermission().then(perm=>{
if(perm===‘granted’){
scheduleReminders(time,_reminderDays);
showAl(‘🔔 Reminders set!’,`You'll get a nudge at ${time} on your chosen days. Make sure to keep your browser open for reminders to fire.`,[{text:‘Got it’,style:‘primary’}]);
} else {
showAl(‘Reminder saved’,`Time saved as ${time}. Enable browser notifications for this site to receive alerts.`,[{text:‘OK’,style:‘primary’}]);
}
});
} else if(‘Notification’ in window && Notification.permission===‘granted’){
scheduleReminders(time,_reminderDays);
showAl(‘🔔 Reminders updated’,`Set for ${time}.`,[{text:‘Done’,style:‘primary’}]);
} else {
showAl(‘Reminder saved’,`Your reminder time is saved as ${time}. Enable notifications for this site in your browser settings to receive alerts.`,[{text:‘OK’,style:‘primary’}]);
}
renderProfile();
}
function scheduleReminders(timeStr,days){
// Simple: check every minute if it’s time (works while tab open)
const [h,m]=timeStr.split(’:’).map(Number);
if(window._reminderInterval)clearInterval(window._reminderInterval);
window._reminderInterval=setInterval(()=>{
const now=new Date();
if(now.getHours()===h&&now.getMinutes()===m&&days.includes(now.getDay()===0?6:now.getDay()-1)){
const lastFired=localStorage.getItem(‘wl_reminder_last’);
const today=now.toDateString();
if(lastFired!==today){
localStorage.setItem(‘wl_reminder_last’,today);
new Notification(‘Time to work out 💪’,{
body:“Your body is ready. Open FitLogix and get after it.”,
icon:‘data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><text y="20" font-size="20">💪</text></svg>’
});
}
}
},30000); // check every 30s
}

