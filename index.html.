applySystemTheme(); // follow system if no explicit choice
applyTheme();
startTrial(); // begin 7-day free trial on first open
// Init rest ring and active ring
const r=86,c=2*Math.PI*r;
[‘rest-arc’,‘active-arc’].forEach(id=>{
const arc=document.getElementById(id);
if(arc){arc.style.strokeDasharray=c;arc.style.strokeDashoffset=0;}
});
// Sound pill
document.getElementById(‘sound-pill’)?.classList.toggle(‘on’,soundEnabled);
document.getElementById(‘sound-lbl’)?.textContent;
if(localStorage.getItem(OK)&&lvl){
updateBadge();renderToday();showView(‘v-today’);setActiveTab(‘today’);
}else{showView(‘v-onboard’);}
})();
</script>

