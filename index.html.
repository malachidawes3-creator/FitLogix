if(selEx){selEx.totalSets=custSets;if(selEx.mode===‘reps’)selEx.repsPerSet=custReps;selEx.restSeconds=custRest;}
// Live update HIIT/sprint hint
if(selEx?.type===‘hiit’||selEx?.type===‘sprints’){const hint=document.querySelector(’.custom-hint’);if(hint&&selEx.type===‘hiit’)hint.textContent=`${custSets} rounds · ${selEx.secsPerSet}s on / ${custRest}s off · ~${Math.round(custSets*(selEx.secsPerSet+custRest)/60)} min total`;}
}
