function showDayDetail(dateStr){const ws=loadWs();const dayWs=ws.filter(w=>new Date(w.createdAt).toDateString()===dateStr);if(!dayWs.length)return;const date=new Date(dateStr).toLocaleDateString([],{weekday:'long',month:'long',day:'numeric'});const cals=dayWs.reduce((s,w)=>s+(w.caloriesBurned||0),0);showAl(date,`${dayWs.length} workout${dayWs.length!==1?'s':''} · ${cals} kcal\n\n${dayWs.map(w=>w.exerciseName+': '+w.amount+' '+w.unit).join('\n')}`,[{text:'Close',style:'cancel'}]);}
function showAchDetail(id){const a=ACHIEVEMENTS.find(a=>a.id===id);if(!a)return;const ws=loadWs();const streak=calcStreak();const earned=getEarnedAchs(ws,streak).some(ea=>ea.id===id);let prog={cur:0,max:1};try{prog=a.progress?a.progress(ws,streak):{cur:earned?1:0,max:1};}catch(e){}const pct=Math.min(100,Math.round((prog.cur/prog.max)*100));showAl(`${a.icon} ${a.name}`,`${a.desc}\n\n${earned?'\u2705 Earned!':pct>0?'Progress: '+prog.cur.toLocaleString()+' / '+prog.max.toLocaleString()+' ('+pct+'%)':'Not started yet'}`,[{text:'Got it',style:'primary'}]);}
let histFilterType='all';
function setHistFilter(type){
  histFilterType=type;
  document.querySelectorAll('.hist-filter-chip').forEach(c=>{
    c.classList.toggle('active',c.dataset.type===type);
  });
  renderHist();
}

function renderHist(){
  const allWs=loadWs();
  const isPrem=isPremium();
  const cutoff=Date.now()-(14*24*60*60*1000);
  const prem_ws=isPrem?allWs:allWs.filter(w=>new Date(w.createdAt).getTime()>=cutoff);
  const hiddenCount=allWs.length-prem_ws.length;

  // Apply type filter and search
  const query=(document.getElementById('hist-search')?.value||'').toLowerCase().trim();
  const ws=prem_ws.filter(w=>{
    const matchType=histFilterType==='all'||w.type===histFilterType;
    const matchSearch=!query||w.exerciseName.toLowerCase().includes(query)||(w.notes||'').toLowerCase().includes(query);
    return matchType&&matchSearch;
  });

  // Build filter chips from available types
  const typesInHistory=[...new Set(prem_ws.map(w=>w.type))];
  const filtersEl=document.getElementById('hist-filters');
  if(filtersEl&&filtersEl.children.length===0){
    filtersEl.innerHTML=`<button class="hist-filter-chip${histFilterType==='all'?' active':''}" data-type="all" onclick="setHistFilter('all')">All</button>`
      +typesInHistory.map(t=>{const ex=EX.find(e=>e.type===t)||EX[11];return`<button class="hist-filter-chip${histFilterType===t?' active':''}" data-type="${t}" onclick="setHistFilter('${t}')">${ex.label}</button>`;}).join('');
  }

  document.getElementById('hist-sub').textContent=`${ws.length} workout${ws.length!==1?'s':''}${hiddenCount>0?` · ${hiddenCount} older hidden`:''}`;
  const list=document.getElementById('hist-list');
  if(!ws.length){
    list.innerHTML=`<div class="empty-box"><div class="empty-ico">${svg('clock')}</div><div class="empty-t">${query||histFilterType!=='all'?'No results':'No history yet'}</div><div class="empty-s">${query||histFilterType!=='all'?'Try a different search or filter.':'Your completed workouts will appear here.'}</div></div>${hiddenCount>0?`<div class="trial-banner" onclick="openPremiumSheet('unlimited history')" style="margin-top:12px"><div class="trial-banner-ico">🔒</div><div class="trial-banner-text"><div class="trial-banner-title">${hiddenCount} older workout${hiddenCount!==1?'s':''} hidden</div><div class="trial-banner-sub">Upgrade to see your full history.</div></div><div class="trial-banner-cta">Unlock →</div></div>`:''}`;
    return;
  }
  const g={};ws.forEach(w=>{const d=new Date(w.createdAt).toDateString();if(!g[d])g[d]=[];g[d].push(w);});
  const today=new Date().toDateString(),yest=new Date(Date.now()-86400000).toDateString();
  const fd=d=>d===today?'Today':d===yest?'Yesterday':new Date(d).toLocaleDateString([],{weekday:'long',month:'short',day:'numeric'});
  list.innerHTML=Object.entries(g).map(([date,dw])=>{const dc=dw.reduce((s,w)=>s+(w.caloriesBurned||0),0);return`<div><div class="date-hdr"><div class="date-t">${fd(date)}</div><div class="date-s">${dw.length} exercise${dw.length!==1?'s':''}${dc>0?` · ~${dc} kcal`:''}</div></div>${dw.map(wCard).join('')}</div>`;}).join('')
    +(hiddenCount>0?`<div class="trial-banner" onclick="openPremiumSheet('unlimited history')" style="margin-top:12px"><div class="trial-banner-ico">🔒</div><div class="trial-banner-text"><div class="trial-banner-title">${hiddenCount} older workout${hiddenCount!==1?'s':''} hidden</div><div class="trial-banner-sub">Upgrade to unlock your full history.</div></div><div class="trial-banner-cta">Unlock →</div></div>`:'');
}

