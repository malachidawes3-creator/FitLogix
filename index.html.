const TAB_ORDER=['v-onboard','v-today','v-setup','v-active','v-rest','v-done','v-body','v-history','v-stats','v-profile'];
let currentViewId='v-onboard';

function showView(id){
  const oldId=currentViewId;
  const oldEl=document.getElementById(oldId);
  const newEl=document.getElementById(id);
  if(!newEl)return;
  if(oldId===id){newEl.classList.add('show');return;}

  const oldIdx=TAB_ORDER.indexOf(oldId);
  const newIdx=TAB_ORDER.indexOf(id);

  // Workout/active/rest/done slide UP from bottom (modal feel)
  const upGroup=new Set(['v-setup','v-active','v-rest','v-done']);
  const isUpTransition=upGroup.has(id)&&!upGroup.has(oldId);
  const isDownTransition=!upGroup.has(id)&&upGroup.has(oldId);

  // Show new view immediately (display:flex) before animating
  if(oldEl){oldEl.style.zIndex='1';}
  newEl.style.zIndex='2';
  newEl.classList.add('show');
  currentViewId=id;

  // Remove any leftover animation classes
  [oldEl,newEl].forEach(el=>{
    if(!el)return;
    el.classList.remove('slide-in-right','slide-in-left','slide-out-right','slide-out-left','slide-in-up','slide-out-down');
  });

  if(isUpTransition){
    newEl.classList.add('slide-in-up');
  } else if(isDownTransition){
    newEl.classList.add('slide-in-up'); // still slide up on return, less jarring
  } else if(newIdx>oldIdx){
    // Moving right (forward)
    newEl.classList.add('slide-in-right');
    if(oldEl)oldEl.classList.add('slide-out-left');
  } else {
    // Moving left (back)
    newEl.classList.add('slide-in-left');
    if(oldEl)oldEl.classList.add('slide-out-right');
  }

  // Hide old view after animation completes
  if(oldEl){
    setTimeout(()=>{
      oldEl.classList.remove('show');
      oldEl.classList.remove('slide-out-left','slide-out-right','slide-out-down');
      oldEl.style.zIndex='';
      newEl.style.zIndex='';
    },300);
  }
}

// ── Typewriter ──
// speed: ms per character (medium = 45ms)
function typewriter(el, text, speed=45, onDone){
  if(!el)return;
  el.textContent='';
  el.classList.add('typewriter-cursor');
  let i=0;
  function type(){
    if(i<text.length){
      el.textContent+=text[i++];
      setTimeout(type, speed+(Math.random()*20-10)); // slight randomness feels human
    } else {
      el.classList.remove('typewriter-cursor');
      if(onDone)onDone();
    }
  }
  type();
}

// Typewriter for longer blocks (paragraphs) — word by word, faster
function typewriterWords(el, text, speed=38, onDone){
  if(!el)return;
  el.textContent='';
  el.classList.add('typewriter-cursor');
  const words=text.split(' ');
  let i=0;
  function typeWord(){
    if(i<words.length){
      el.textContent+=(i>0?' ':'')+words[i++];
      setTimeout(typeWord, speed+(Math.random()*15));
    } else {
      el.classList.remove('typewriter-cursor');
      if(onDone)onDone();
    }
  }
  typeWord();
}

// ── Number roll ──
function rollNumber(el, target, duration=700, suffix=''){
  if(!el)return;
  const start=performance.now();
  const startVal=0;
  el.classList.add('rolling');
  function tick(now){
    const elapsed=now-start;
    const progress=Math.min(elapsed/duration,1);
    // Ease out cubic
    const eased=1-Math.pow(1-progress,3);
    const current=Math.round(startVal+(target-startVal)*eased);
    el.textContent=current.toLocaleString()+suffix;
    if(progress<1)requestAnimationFrame(tick);
    else{el.textContent=target.toLocaleString()+suffix;el.classList.remove('rolling');}
  }
  requestAnimationFrame(tick);
}

// ── Stagger cards ──
function staggerCards(containerEl, cardClass='.sum-card', delay=90){
  if(!containerEl)return;
  const cards=containerEl.querySelectorAll(cardClass);
  // Mark first so they start invisible
  cards.forEach(card=>card.classList.add('will-animate'));
  requestAnimationFrame(()=>{
    cards.forEach((card,i)=>{
      card.style.animationDelay=`${i*delay}ms`;
      card.classList.add('card-in');
    });
  });
}

