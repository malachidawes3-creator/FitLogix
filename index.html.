function calcStreak(){
  const ws=loadWs();if(!ws.length)return 0;
  const days=new Set(ws.map(w=>new Date(w.createdAt).toDateString()));
  let streak=0,d=new Date();
  if(!days.has(d.toDateString()))d=new Date(d-86400000);
  while(days.has(d.toDateString())){streak++;d=new Date(d-86400000);}
  return streak;
}

