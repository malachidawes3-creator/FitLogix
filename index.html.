const MET_MIN={running:9.8,cycling:7.5,swimming:8.0,sprints:13.5,yoga:3.0,hiit:10.0};
function estCal(type,amount,unit){
  const bwKg=getBwKg();
  if(unit==='reps'){
    const met=MET_RPM[type]||3.0;
    // Approx time: reps × 3s per rep
    const hrs=(amount*3)/3600;
    return Math.round(met*bwKg*hrs);
  }
  if(unit==='minutes'){
    const met=MET_MIN[type]||5.0;
    return Math.round(met*bwKg*(amount/60));
  }
  return 0;
}
function getBwKg(){
  const bw=parseFloat(localStorage.getItem(BWK)||'70');
  const unit=localStorage.getItem(BWU)||'kg';
