function buildNumPad(){
  const keys=['1','2','3','4','5','6','7','8','9','.','0','⌫'];
  document.getElementById('num-pad').innerHTML=keys.map(k=>`<button class="num-key${k==='⌫'?' del':k==='.'?' special':''}" onclick="numKey('${k}')">${k}</button>`).join('');
}
function numKey(k){
  if(k==='⌫'){bwStr=bwStr.slice(0,-1)||'0';}
  else if(k==='.'){if(!bwStr.includes('.'))bwStr+='.';} 
  else{if(bwStr==='0')bwStr=k;else if(bwStr.length<5)bwStr+=k;}
  updateBwDisplay();
}
