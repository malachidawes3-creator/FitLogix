} else if(exerciseType===‘pushups’||exerciseType===‘weights’){
specificFeeling=‘Your chest, shoulders and arms will feel pumped and tight — this is increased blood volume in the muscle, a direct signal for growth.’;
} else if(exerciseType===‘pullups’){
specificFeeling=‘Your lats and biceps should feel pumped and fatigued. That lat soreness tomorrow means your back is responding and growing.’;
} else if(exerciseType===‘squats’){
specificFeeling=‘Your legs may feel shaky or weak — that's normal after heavy squats. The quads and glutes have been worked hard. The soreness tomorrow is a good sign.’;
} else if(exerciseType===‘yoga’){
specificFeeling=‘You should feel looser, calmer, and more centred. Cortisol levels measurably drop after a yoga session — you're less stressed than you were 15 minutes ago.’;
} else if(exerciseType===‘situps’){
specificFeeling=‘Your abs should feel that deep burning tightness — the rectus abdominis is fatigued. The soreness you'll feel tomorrow is your core building real strength.’;
}

// Streak bonus message
let streakMsg=’’;
if(streak>=7) streakMsg=`${streak} days straight — you\'re building a real habit now. This is where permanent change happens.`;
else if(streak>=3) streakMsg=`${streak} days in a row. Keep this momentum — you\'re in the zone.`;
else if(streak===1) streakMsg=‘First session of a new streak. Come back tomorrow to keep it going.’;

return{title,feeling,specificFeeling,motivation,streakMsg,cals:totalCals,mins};
}

function getLiveTip(){const pool=LT[selEx?.type||‘other’];const types=[‘form’,‘perf’,‘mistakes’];const t=types[liveTipRot%3];const arr=pool[t]||[];const lbls={form:‘Form Tip’,perf:‘Performance Tip’,mistakes:‘Watch Out’};return{label:lbls[t],text:arr[tipIdx%arr.length]};}

function updateActiveUI(startCountdown=true){
// Reset pause state for new set
isPaused=false;
resetTapReps();
const pb=document.getElementById(‘pause-btn’);
const pi=document.getElementById(‘pause-icon’);
const db=document.querySelector(’#v-active .btn-cta’);
if(pb)pb.classList.remove(‘paused’);
if(pi)pi.innerHTML=’<rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>’;
if(db){db.style.opacity=’’;db.style.pointerEvents=’’;}

const ex=selEx;
document.getElementById(‘active-title’).textContent=selRoutine?selRoutine.name:ex.label;
document.getElementById(‘rest-title’).textContent=selRoutine?selRoutine.name:ex.label;
renderDots(‘a-dots’);
document.getElementById(‘set-lbl’).textContent=`Set ${curSet} of ${ex.totalSets}`;
document.getElementById(‘elapsed’).textContent=‘Total: ‘+fmt(elapsed);
document.getElementById(‘a-instr’).textContent=ex.instruction(curSet,ex.totalSets);
const rp=document.getElementById(‘rp-wrap’);
if(selRoutine&&selRoutine.exercises.length>1){const dots=selRoutine.exercises.map((e,i)=>`<div class="rp-dot ${i<routineExIdx?'done':i===routineExIdx?'cur':''}"></div>`).join(’’);rp.innerHTML=`<div class="rp-bar"><div class="rp-lbl">Exercise ${routineExIdx+1} of ${selRoutine.exercises.length}: ${ex.label}</div><div class="rp-dots">${dots}</div></div>`;}else{rp.innerHTML=’’;}
// Show post-set feeling message if not on the first set, otherwise live tip
const feeling=curSet>1?getPostSetFeeling():null;
const tip=feeling||getLiveTip();
document.getElementById(‘tip-lbl’).textContent=feeling?feeling.lbl:tip.label;
document.getElementById(‘a-tip’).textContent=feeling?feeling.msg:tip.text;
const isLastSet=curSet>=ex.totalSets,isLastEx=!selRoutine||routineExIdx>=selRoutine.exercises.length-1;
document.getElementById(‘done-lbl’).textContent=(isLastSet&&isLastEx)?‘Finish Workout’:‘Done — Next Set’;
// Set the phase label
const pl=document.getElementById(‘active-phase-lbl’);
if(pl){pl.textContent=‘SET TIME’;pl.style.color=‘var(–tint)’;}
const numEl=document.getElementById(‘active-num’);
if(numEl)numEl.style.fontSize=‘52px’;
// Start the countdown
if(startCountdown){
const secs=ex.secsPerSet||30;
startActiveCountdown(secs);
}
}

function startRestTimer(secs,onDone){
restTotal=secs;
document.getElementById(‘rest-num’).textContent=secs;
updateRing(secs,restTotal);
let rem=secs;
// Rotate tip: every 3rd rest shows a hydration/recovery tip
const restTipEl=document.getElementById(‘r-tip’);
if(restTipEl){
const HYDRATION=[‘Sip water now — even mild dehydration cuts strength by 10%.’,‘Deep breath: inhale 4 counts, exhale 6. Clears lactic acid faster.’,‘Shake out your hands and relax your shoulders completely.’,‘Use this rest fully. The recovery IS part of the workout.’];
restTipEl.textContent=(doneSet%3===0)?HYDRATION[doneSet%HYDRATION.length]:getLiveTip().text;
}
// Populate the feeling/prep card during rest
const feelingEl=document.getElementById(‘rest-feeling’);
if(feelingEl){
const feeling=getPostSetFeeling();
if(feeling){
// Set 2+ - show how body should feel right now
feelingEl.innerHTML=` <div class="feeling-check-label">${feeling.lbl}</div> <div class="feeling-check-text">${feeling.msg}</div>`;
feelingEl.style.display=‘block’;
} else {
// Set 1 - show prep tip for what’s coming
const ex=selEx;
const nextSetNum=curSet+1;
const prepMsgs=[
‘Breathe in through your nose, out through your mouth. Full lungs before you start.’,
‘Visualise the movement before you do it. Mind-muscle connection starts now.’,
‘Shake out your hands. Roll your shoulders. Get ready.’,
‘This rest is part of the workout. Use it fully.’,
];
const prep=prepMsgs[(curSet-1)%prepMsgs.length];
feelingEl.innerHTML=` <div class="feeling-check-label">⚡ GET READY</div> <div class="feeling-check-text">${prep}</div>`;
feelingEl.style.display=‘block’;
}
}
restTmr=setInterval(()=>{
rem–;
document.getElementById(‘rest-num’).textContent=rem;
tickNum();
if(rem<=3&&rem>0){playTick(true,false);setTimeout(()=>playTick(true,false),80);}
else{playTick(rem<=5,false);}
updateRing(rem,restTotal);
if(rem<=0){clrR();playDone();onDone();}
},1000);
}

function handleStart(){
if(!selEx&&!selRoutine)return;
getAudioCtx();
if(selRoutine)selEx=selRoutine.exercises[0];
routineExIdx=0;curSet=1;doneSet=0;elapsed=0;totAccum=0;tipIdx=0;liveTipRot=0;
clrA();
showView(‘v-active’);updateActiveUI(false); // show ring without countdown yet
// 3-2-1 countdown then start
preSetCountdown(()=>{
updateActiveUI(true);
setTimeout(startT,50);
});
}

function handleSetDone(){
if(!selEx)return;
clrA(); // stop the set countdown
playSetDone();
doneSet++;liveTipRot++;tipIdx++;
const isLastSet=curSet>=selEx.totalSets;
if(isLastSet){
if(selRoutine&&routineExIdx<selRoutine.exercises.length-1){
const nextEx=selRoutine.exercises[routineExIdx+1];
const restSecs=selEx.restSeconds||45;
if(restSecs===0){routineExIdx++;loadNextEx();}
else{pauseT();const tip=getLiveTip();document.getElementById(‘r-tip’).textContent=tip.text;document.getElementById(‘next-lbl’).textContent=`Next up: ${nextEx.label} — ${nextEx.totalSets} set${nextEx.totalSets!==1?'s':''}`;renderDots(‘r-dots’);showView(‘v-rest’);startRestTimer(restSecs,()=>{routineExIdx++;loadNextEx();});}
}else{finishW();}
}else{
curSet++;
if(selEx.restSeconds===0){updateActiveUI();}
else{pauseT();const tip=getLiveTip();document.getElementById(‘r-tip’).textContent=tip.text;document.getElementById(‘next-lbl’).textContent=’Coming up: ’+selEx.instruction(curSet,selEx.totalSets);renderDots(‘r-dots’);showView(‘v-rest’);startRestTimer(selEx.restSeconds,()=>goNextSet());}
}
}

function loadNextEx(){selEx=selRoutine.exercises[routineExIdx];curSet=1;doneSet=0;tipIdx=0;clrA();showView(‘v-active’);updateActiveUI(true);startT();}
function handleSkipRest(){clrR();if(selRoutine&&curSet>=selEx.totalSets&&routineExIdx<selRoutine.exercises.length-1){routineExIdx++;loadNextEx();}else{goNextSet();}}
function goNextSet(){clrA();showView(‘v-active’);updateActiveUI(true);startT();}

function finishW(){
clrT();clrR();clrA();
const ts=totAccum+Math.floor((Date.now()-totStart)/1000);
let totalReps=0,totalCals=0,totalSets=0;
const newPRs=[];

const processEx=(ex,amount,unit,durationSecs)=>{
const c=estCal(ex.type,amount,unit);
totalCals+=c;totalSets+=ex.totalSets||1;
if(ex.mode===‘reps’)totalReps+=amount;
const pr=checkAndUpdatePR(ex.type,amount,unit);
if(pr.isNew)newPRs.push({…pr,label:ex.label});
const w=addW({exerciseName:ex.label,type:ex.type,amount,unit,durationSeconds:durationSecs,caloriesBurned:c||undefined});
return w.id;
};

let lastWid=null;
if(selRoutine){
selRoutine.exercises.forEach(ex=>{
const perExSecs=Math.round(ts/selRoutine.exercises.length);
const amount=ex.mode===‘reps’?ex.totalSets*ex.repsPerSet:parseFloat((perExSecs/60).toFixed(1));
lastWid=processEx(ex,amount,ex.unit,perExSecs);
});
}else{
const amount=selEx.mode===‘reps’?doneSet*selEx.repsPerSet:parseFloat((ts/60).toFixed(1));
lastWid=processEx(selEx,amount,selEx.unit,ts);
}

playDone();
const ws=loadWs();const streak=calcStreak();
const newAchs=getNewAchs(ws,streak);

// Dynamic post-workout response
// For routines, pick the exercise type that was done the most sets
let primaryType;
if(selRoutine){
const typeSets={};
selRoutine.exercises.forEach(ex=>{typeSets[ex.type]=(typeSets[ex.type]||0)+ex.totalSets;});
primaryType=Object.entries(typeSets).sort((a,b)=>b[1]-a[1])[0][0];
} else {
primaryType=selEx.type;
}
const response=getWorkoutResponse(totalSets,totalCals,ts,primaryType,streak);
// Set done-title empty - typewriter will fill it after view transition
document.getElementById(‘done-title’).textContent=’’;
document.getElementById(‘done-sub’).innerHTML=’’;

const exCard=selRoutine&&selRoutine.exercises.length>1?`<div class="sum-card"><svg viewBox="0 0 24 24" style="stroke:var(--blue)">${IC['layers']}</svg><div class="sum-val">${selRoutine.exercises.length}</div><div class="sum-unit">exercises</div></div>`:’’;
const repsCard=totalReps>0?`<div class="sum-card"><svg viewBox="0 0 24 24" style="stroke:var(--tint)">${IC['target']}</svg><div class="sum-val">${totalReps}</div><div class="sum-unit">total reps</div></div>`:’’;
const calCard=totalCals>0?`<div class="sum-card amb"><svg viewBox="0 0 24 24" style="stroke:var(--amber)">${IC['zap']}</svg><div class="sum-val">~${totalCals}</div><div class="sum-unit">kcal burned</div></div>`:’’;
document.getElementById(‘sum-grid’).innerHTML=`<div class="sum-card"><svg viewBox="0 0 24 24" style="stroke:var(--tint)">${IC['layers']}</svg><div class="sum-val">${totalSets}</div><div class="sum-unit">sets done</div></div>${exCard}${repsCard}<div class="sum-card"><svg viewBox="0 0 24 24" style="stroke:var(--tint)">${IC['clock']}</svg><div class="sum-val">${fmt(ts)}</div><div class="sum-unit">duration</div></div>${calCard}`;

// How you should feel right now + motivation block
// Feeling text starts empty - typewriter fills it
const feelingHtml=` <div class="done-feeling-card"> <div class="done-feeling-label">💭 How you should feel right now</div> <div class="done-feeling-text" id="feeling-text-target"></div> ${response.specificFeeling?`<div class="done-feeling-specific" id="feeling-specific-target" style="opacity:0"></div>`:''} </div> <div class="done-motivation-card"> <div class="done-motivation-text" id="motivation-text-target"></div> ${response.streakMsg?`<div class="done-streak-msg" id="streak-msg-target" style="opacity:0">🔥 ${response.streakMsg}</div>`:''} </div>`;

document.getElementById(‘new-pr-wrap’).innerHTML=newPRs.map(pr=>`<div class="pr-badge fade-up"><div class="pr-badge-ico">🏅</div><div class="pr-badge-txt">New PR! ${pr.label}: ${pr.new} ${pr.unit}${pr.prev?` (was ${pr.prev})`:''}</div></div>`).join(’’);
document.getElementById(‘new-ach-wrap’).innerHTML=newAchs.map(a=>`<div class="new-ach-banner fade-up"><div class="new-ach-banner-ico">${a.icon}</div><div class="new-ach-info"><div class="new-ach-title">Achievement Unlocked!</div><div class="new-ach-name">${a.name}</div></div></div>`).join(’’)+feelingHtml;

showView(‘v-done’);
setTimeout(launchConfetti, 300);

// Stagger sum-grid cards in
setTimeout(()=>{
staggerCards(document.getElementById(‘sum-grid’),’.sum-card’,100);
},200);

// Typewriter sequence: title → sub → feeling → motivation
const titleEl=document.getElementById(‘done-title’);
const subEl=document.getElementById(‘done-sub’);
setTimeout(()=>{
typewriter(titleEl, response.title, 45, ()=>{
// Sub line appears after title
setTimeout(()=>{
if(subEl)subEl.innerHTML=`<span style="color:var(--text2);font-size:14px">Session saved · ${response.mins} min${response.cals>0?` · ~${response.cals} kcal`:''}`;
subEl?.classList.add(‘fade-up’);
// Feeling text types out
setTimeout(()=>{
const feelEl=document.getElementById(‘feeling-text-target’);
if(feelEl)typewriterWords(feelEl, response.feeling, 32, ()=>{
// Specific feeling fades in
const specEl=document.getElementById(‘feeling-specific-target’);
if(specEl){specEl.style.opacity=‘1’;specEl.style.transition=‘opacity .4s’;specEl.textContent=response.specificFeeling;}
// Motivation types
setTimeout(()=>{
const motEl=document.getElementById(‘motivation-text-target’);
if(motEl)typewriterWords(motEl, response.motivation, 30, ()=>{
const sEl=document.getElementById(‘streak-msg-target’);
if(sEl){sEl.style.opacity=‘1’;sEl.style.transition=‘opacity .5s’;}
});
},300);
});
},400);
},200);
});
},350); // slight delay after slide-in completes

if(isPremium())setTimeout(()=>openNotesSheet(lastWid), 3500); // wait for typewriter
}

async function handleEndEarly(){
if(!selEx)return;
if(doneSet===0&&curSet===1){const i=await showAl(‘End workout?’,‘No sets completed yet. Discard this session?’,[{text:‘Keep going’,style:‘cancel’},{text:‘Discard’,style:‘destructive’}]);if(i===1){clrT();clrR();clrA();goToday();}return;}
const i=await showAl(‘End early?’,‘Save your progress and finish?’,[{text:‘Keep going’,style:‘cancel’},{text:‘Save & finish’,style:‘primary’}]);
if(i===1)finishW();
}
function handleDiscard(){const cur=VIEWS.find(v=>document.getElementById(v)?.classList.contains(‘show’));if(cur===‘v-active’||cur===‘v-rest’)handleEndEarly();else goToday();}

