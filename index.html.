<!DOCTYPE html>

<html lang="en" id="html-root">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
<title>FitLogix</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}

/* ── THEME VARIABLES ── */
:root{
–font:‘Plus Jakarta Sans’,sans-serif;–mono:‘DM Mono’,monospace;
–r:18px;–r-sm:12px;
–bot-pad:max(20px,env(safe-area-inset-bottom));
–top-pad:max(20px,env(safe-area-inset-top));
–tint:#3dd68c;–tint-dim:rgba(61,214,140,0.11);–tint-glow:rgba(61,214,140,0.22);
–error:#f87171;–amber:#fbbf24;–amber-dim:rgba(251,191,36,0.11);
–blue:#60a5fa;–blue-dim:rgba(96,165,250,0.11);
–purple:#a78bfa;
}

/* DARK theme (default) */
.theme-dark{
–bg:#0b0d10;–bg2:#111318;–card:#181b22;–card2:#1e2129;–border:#252a35;
–text:#eef0f4;–text2:#8892a4;–text3:#4a5468;–shadow:rgba(0,0,0,0.4);
}
/* LIGHT theme */
.theme-light{
–bg:#f5f6f8;–bg2:#ffffff;–card:#ffffff;–card2:#f0f1f4;–border:#e2e5ec;
–text:#0d0f14;–text2:#5a6275;–text3:#9ba3b4;–shadow:rgba(0,0,0,0.08);
–tint-dim:rgba(25,180,100,0.1);–tint-glow:rgba(25,180,100,0.2);
}
.theme-light .hero{background:linear-gradient(135deg,#d4f5e5 0%,#ddeeff 100%)!important;border-color:rgba(61,214,140,0.25)!important;}
.theme-light .ob-logo,.theme-light #v-onboard{background:linear-gradient(160deg,#e8faf0 0%,#f5f6f8 60%)!important;}

html,body{height:100%;background:var(–bg);color:var(–text);font-family:var(–font);overflow:hidden;-webkit-tap-highlight-color:transparent;overscroll-behavior:none;}
#app{position:fixed;inset:0;max-width:440px;margin:0 auto;display:flex;flex-direction:column;background:var(–bg);}

/* ── TABS ── */
#tabbar{flex-shrink:0;display:flex;background:var(–bg2);border-top:1px solid var(–border);padding:8px 4px var(–bot-pad);gap:2px;}
.tab-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;background:none;border:none;cursor:pointer;padding:6px 2px;border-radius:12px;color:var(–text3);transition:color .2s,background .2s;}
.tab-btn.active{color:var(–tint);background:var(–tint-dim);}
.tab-btn svg{width:20px;height:20px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.tab-btn span{font-size:9px;font-weight:600;}

/* ── VIEWS ── */
/* ── SLIDE TRANSITIONS ── */
#content{flex:1;overflow:hidden;position:relative;}
.view{position:absolute;inset:0;display:none;flex-direction:column;background:var(–bg);overflow:hidden;will-change:transform;}
.view.show{display:flex;}
.view.slide-in-right{animation:slideInRight .28s cubic-bezier(.32,.72,0,1) forwards;}
.view.slide-in-left{animation:slideInLeft .28s cubic-bezier(.32,.72,0,1) forwards;}
.view.slide-out-right{animation:slideOutRight .28s cubic-bezier(.32,.72,0,1) forwards;}
.view.slide-out-left{animation:slideOutLeft .28s cubic-bezier(.32,.72,0,1) forwards;}
@keyframes slideInRight{from{transform:translateX(100%);opacity:0.6;}to{transform:translateX(0);opacity:1;}}
@keyframes slideInLeft{from{transform:translateX(-100%);opacity:0.6;}to{transform:translateX(0);opacity:1;}}
@keyframes slideOutRight{from{transform:translateX(0);opacity:1;}to{transform:translateX(100%);opacity:0;}}
@keyframes slideOutLeft{from{transform:translateX(0);opacity:1;}to{transform:translateX(-100%);opacity:0;}}

/* Upward reveal for non-tab views (workout, done, etc) */
.view.slide-in-up{animation:slideInUp .3s cubic-bezier(.32,.72,0,1) forwards;}
.view.slide-out-down{animation:slideOutDown .25s cubic-bezier(.32,.72,0,1) forwards;}
@keyframes slideInUp{from{transform:translateY(40px);opacity:0;}to{transform:translateY(0);opacity:1;}}
@keyframes slideOutDown{from{transform:translateY(0);opacity:1;}to{transform:translateY(30px);opacity:0;}}

/* ── TYPEWRITER ── */
.typewriter-cursor::after{content:’|’;animation:blink .7s step-end infinite;color:var(–tint);font-weight:300;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0;}}

/* ── NUMBER ROLL ── */
.hero-val{transition:none;}
.hero-val.rolling{font-variant-numeric:tabular-nums;}

/* ── STAGGERED CARDS ── */
.sum-card{opacity:1;}
.sum-card.will-animate{opacity:0;}
.sum-card.card-in{animation:cardPop .35s cubic-bezier(.34,1.56,.64,1) forwards;}
@keyframes cardPop{from{opacity:0;transform:scale(0.85) translateY(12px);}to{opacity:1;transform:scale(1) translateY(0);}}

/* ── SET COMPLETE FLASH ── */
@keyframes setFlash{0%{color:var(–tint);transform:scale(1.15);}100%{color:var(–tint);transform:scale(1);}}
.set-lbl.flashing{animation:setFlash .35s ease forwards;}
.vscroll{flex:1;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;overscroll-behavior:contain;}
.vscroll::-webkit-scrollbar{display:none;}
.vpad{padding:16px 20px 24px;}
.vfooter{flex-shrink:0;padding:12px 20px var(–bot-pad);background:var(–bg);border-top:1px solid var(–border);}
.vhead{flex-shrink:0;padding:var(–top-pad) 20px 14px;}
.vhead-row{display:flex;align-items:flex-start;justify-content:space-between;gap:10px;}
.vtitle{font-size:28px;font-weight:800;}
.vsub{font-size:13px;color:var(–text2);margin-top:3px;}
.live-hdr{flex-shrink:0;display:flex;align-items:center;justify-content:space-between;padding:var(–top-pad) 20px 14px;border-bottom:1px solid var(–border);}
.ico-btn{background:var(–card);border:1px solid var(–border);border-radius:12px;width:42px;height:42px;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;}
.ico-btn:active{background:var(–card2);}
.ico-btn svg{width:20px;height:20px;stroke:var(–text);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.live-title{font-size:17px;font-weight:700;}
.end-btn{background:none;border:none;cursor:pointer;font-size:15px;font-weight:600;color:var(–error);font-family:var(–font);padding:8px;width:42px;text-align:right;}
.w42{width:42px;flex-shrink:0;}
.sec-lbl{font-size:11px;font-weight:700;letter-spacing:1px;color:var(–text3);text-transform:uppercase;margin-bottom:12px;}

/* ── BUTTONS ── */
.btn-cta{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;padding:20px;border-radius:var(–r);border:none;background:var(–tint);color:#000;font-size:17px;font-weight:800;font-family:var(–font);cursor:pointer;box-shadow:0 4px 32px var(–tint-glow);transition:opacity .15s,transform .1s;}
.btn-cta:active{opacity:0.9;transform:scale(0.98);}
.btn-cta svg{width:22px;height:22px;stroke:#000;fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round;}
.btn-cta.off{background:var(–card);color:var(–text3);box-shadow:none;cursor:not-allowed;}
.btn-cta.off svg{stroke:var(–text3);}
.btn-skip{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:18px;border-radius:var(–r);border:1.5px solid var(–border);background:var(–card);color:var(–text);font-size:16px;font-weight:600;font-family:var(–font);cursor:pointer;}
.btn-skip:active{background:var(–card2);}
.btn-skip svg{width:18px;height:18px;stroke:var(–text);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}

/* ── CARDS ── */
.card{background:var(–card);border:1px solid var(–border);border-radius:var(–r);padding:18px;margin-bottom:14px;}
.tip-box{display:flex;align-items:flex-start;gap:10px;background:var(–tint-dim);border:1px solid rgba(61,214,140,0.15);border-radius:var(–r-sm);padding:14px;}
.tip-box svg{width:15px;height:15px;stroke:var(–tint);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;margin-top:2px;}
.tip-lbl{font-size:10px;font-weight:700;letter-spacing:0.8px;color:var(–tint);text-transform:uppercase;margin-bottom:4px;}
.tip-txt{font-size:13px;color:var(–text2);line-height:1.55;}
.dots{display:flex;gap:6px;align-items:center;justify-content:center;}
.dot{height:8px;border-radius:4px;transition:all .3s;}
.empty-box{display:flex;flex-direction:column;align-items:center;gap:14px;background:var(–card);border:1px solid var(–border);border-radius:20px;padding:44px 24px;text-align:center;}
.empty-ico{width:60px;height:60px;border-radius:18px;background:var(–bg2);display:flex;align-items:center;justify-content:center;}
.empty-ico svg{width:28px;height:28px;stroke:var(–text3);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;}
.empty-t{font-size:18px;font-weight:700;}
.empty-s{font-size:14px;color:var(–text2);line-height:1.6;max-width:240px;}
.lvl-badge{display:flex;align-items:center;gap:6px;background:var(–card);border:1px solid var(–border);border-radius:20px;padding:6px 12px;cursor:pointer;flex-shrink:0;}
.lvl-badge:active{background:var(–card2);}
.lvl-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.lvl-txt{font-size:12px;font-weight:600;color:var(–text2);}
.wcard{display:flex;align-items:center;gap:12px;background:var(–card);border:1px solid var(–border);border-radius:var(–r);padding:14px;margin-bottom:10px;}
.wcard:active{background:var(–card2);}
.wcard-ico{width:44px;height:44px;border-radius:12px;background:var(–tint-dim);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.wcard-ico svg{width:20px;height:20px;stroke:var(–tint);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.wcard-info{flex:1;min-width:0;}
.wcard-name{font-size:15px;font-weight:700;}
.wcard-meta{display:flex;align-items:center;gap:6px;margin-top:4px;flex-wrap:wrap;}
.wcard-amt{font-size:13px;color:var(–text2);}
.wcard-note{font-size:12px;color:var(–text3);margin-top:3px;font-style:italic;}
.cal-pill{display:flex;align-items:center;gap:3px;background:var(–amber-dim);border-radius:20px;padding:3px 8px;}
.cal-pill svg{width:10px;height:10px;stroke:var(–amber);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.cal-pill span{font-size:11px;color:var(–amber);font-weight:600;}
.pr-pill{display:flex;align-items:center;gap:3px;background:rgba(167,139,250,0.13);border-radius:20px;padding:3px 8px;}
.pr-pill span{font-size:11px;color:var(–purple);font-weight:700;}
.wcard-time{font-size:12px;color:var(–text3);white-space:nowrap;}
.trash-btn{background:none;border:none;cursor:pointer;padding:8px;opacity:0.4;}
.trash-btn:hover,.trash-btn:active{opacity:1;}
.trash-btn svg{width:16px;height:16px;stroke:var(–text2);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}

/* ── HERO ── */
.hero{background:linear-gradient(135deg,#0e2318 0%,#0e1a28 100%);border:1px solid rgba(61,214,140,0.18);border-radius:var(–r);padding:20px;margin-bottom:20px;position:relative;overflow:hidden;}
.hero::after{content:’’;position:absolute;top:-60px;right:-60px;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(61,214,140,0.1) 0%,transparent 65%);pointer-events:none;}
.hero-lbl{font-size:11px;font-weight:700;letter-spacing:1.2px;color:var(–tint);text-transform:uppercase;margin-bottom:12px;}
.hero-stats{display:flex;gap:20px;flex-wrap:wrap;}
.hero-val{font-size:28px;font-weight:800;font-family:var(–mono);line-height:1;}
.hero-unit{font-size:11px;color:var(–text2);margin-top:3px;}

/* ── WEEKLY ── */
.week-title{font-size:15px;font-weight:700;margin-bottom:14px;}
.week-days{display:flex;gap:5px;justify-content:space-between;margin-bottom:14px;}
.week-day{display:flex;flex-direction:column;align-items:center;gap:4px;flex:1;}
.week-day-dot{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(–text3);background:var(–bg2);border:1.5px solid var(–border);}
.week-day-dot.done{background:var(–tint);color:#000;border-color:var(–tint);}
.week-day-dot.today{border-color:var(–blue);color:var(–blue);}
.week-day-dot.today.done{background:var(–tint);border-color:var(–tint);color:#000;}
.week-day-lbl{font-size:10px;color:var(–text3);font-weight:600;}
.week-stats{display:flex;gap:10px;}
.week-stat{flex:1;background:var(–bg2);border-radius:var(–r-sm);padding:10px;text-align:center;}
.week-stat-v{font-size:18px;font-weight:800;font-family:var(–mono);}
.week-stat-l{font-size:11px;color:var(–text2);margin-top:2px;}

/* ── STATS ── */
.stats-range-row{display:flex;gap:6px;margin-bottom:14px;}
.range-btn{flex:1;padding:9px 4px;border-radius:10px;border:1.5px solid var(–border);background:var(–card);font-size:13px;font-weight:700;color:var(–text3);font-family:var(–font);cursor:pointer;transition:all .15s;}
.range-btn.active{background:var(–tint);border-color:var(–tint);color:#000;}
.stats-tabs{display:flex;background:var(–card2);border-radius:14px;padding:4px;gap:3px;margin-bottom:16px;}
.stats-tab{flex:1;padding:9px 4px;border-radius:11px;border:none;background:none;font-size:13px;font-weight:700;color:var(–text3);font-family:var(–font);cursor:pointer;transition:all .2s;}
.stats-tab.active{background:var(–bg2);color:var(–text);box-shadow:0 1px 4px var(–shadow);}
.wow-card{background:linear-gradient(135deg,#0e1f10 0%,#0a1420 100%);border:1px solid rgba(61,214,140,0.2);border-radius:var(–r);padding:16px;margin-bottom:14px;}
.theme-light .wow-card{background:linear-gradient(135deg,#e8faf0 0%,#ddeeff 100%);}
.wow-title{font-size:11px;font-weight:700;color:var(–text3);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:10px;}
.wow-row{display:flex;align-items:center;justify-content:space-around;}
.wow-item{text-align:center;}
.wow-val{font-size:24px;font-weight:800;font-family:var(–mono);}
.wow-val.pos{color:var(–tint);}
.wow-val.neg{color:var(–error);}
.wow-lbl{font-size:11px;color:var(–text3);margin-top:3px;}
.wow-divider{width:1px;height:36px;background:var(–border);}
.stats-kpi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px;}
.kpi-card{background:var(–card);border:1px solid var(–border);border-radius:var(–r-sm);padding:12px 8px;text-align:center;}
.kpi-val{font-size:18px;font-weight:800;font-family:var(–mono);color:var(–text);line-height:1.2;}
.kpi-lbl{font-size:10px;color:var(–text3);margin-top:3px;font-weight:600;}
.alltime-card{background:var(–card);border:1px solid var(–border);border-radius:var(–r);padding:16px;margin-bottom:14px;}
.alltime-label{font-size:11px;font-weight:700;color:var(–text3);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:10px;}
.alltime-row{display:flex;justify-content:space-around;text-align:center;}
.alltime-val{font-size:22px;font-weight:800;font-family:var(–mono);}
.alltime-unit{font-size:11px;color:var(–text2);margin-top:2px;}
.donut-count{font-size:11px;color:var(–text3);margin-left:2px;}
.heat-row{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-bottom:4px;}
.heat-day-lbl{font-size:9px;font-weight:700;color:var(–text3);text-align:center;}
.heat-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;}
.heat-cell{aspect-ratio:1;border-radius:3px;cursor:pointer;transition:transform .1s;}
.heat-cell:active{transform:scale(0.9);}
.heat-today{outline:2px solid var(–blue);outline-offset:1px;}
.heat-legend{display:flex;align-items:center;gap:5px;margin-top:8px;justify-content:flex-end;}
.ach-summary-row{display:flex;align-items:center;gap:12px;padding:14px 16px;background:var(–card);border:1px solid var(–border);border-radius:var(–r);margin-bottom:16px;}
.ach-summary-earned{font-size:28px;font-weight:800;font-family:var(–mono);color:var(–tint);flex-shrink:0;}
.ach-summary-lbl{font-size:12px;color:var(–text2);flex:1;}
.ach-summary-bar-wrap{width:60px;height:6px;background:var(–border);border-radius:3px;overflow:hidden;flex-shrink:0;}
.ach-summary-bar{height:100%;background:var(–tint);border-radius:3px;transition:width .5s ease;}
.ach-cat-section{margin-bottom:20px;}
.ach-cat-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.ach-cat-name{font-size:12px;font-weight:700;color:var(–text3);text-transform:uppercase;letter-spacing:0.8px;}
.ach-cat-count{font-size:12px;font-weight:700;color:var(–tint);}
.ach-cat-grid{display:flex;flex-direction:column;gap:8px;}
.ach-card-v2{display:flex;align-items:flex-start;gap:12px;background:var(–card);border:1px solid var(–border);border-radius:var(–r-sm);padding:12px 14px;cursor:pointer;position:relative;overflow:hidden;transition:transform .1s;}
.ach-card-v2:active{transform:scale(0.98);}
.ach-card-v2.earned{border-color:var(–amber);background:linear-gradient(135deg,rgba(251,191,36,0.06) 0%,var(–card) 60%);}
.ach-card-v2.locked{opacity:0.45;}
.ach-ico-v2{font-size:26px;flex-shrink:0;line-height:1;margin-top:2px;}
.ach-body{flex:1;min-width:0;}
.ach-name-v2{font-size:14px;font-weight:700;margin-bottom:2px;}
.ach-desc-v2{font-size:12px;color:var(–text2);margin-bottom:6px;line-height:1.4;}
.ach-prog-wrap{height:4px;background:var(–border);border-radius:2px;overflow:hidden;margin-bottom:3px;}
.ach-prog-bar{height:100%;background:var(–tint);border-radius:2px;transition:width .4s ease;}
.ach-prog-lbl{font-size:10px;color:var(–text3);font-weight:600;}
.ach-earned-lbl{font-size:11px;color:var(–amber);font-weight:700;}
.ach-shine{position:absolute;top:0;right:0;width:60px;height:100%;background:linear-gradient(135deg,transparent 40%,rgba(251,191,36,0.08) 60%,transparent 80%);pointer-events:none;}
.stat-row{display:flex;gap:10px;margin-bottom:14px;}
.stat-mini{flex:1;background:var(–card);border:1px solid var(–border);border-radius:var(–r-sm);padding:12px;text-align:center;}
.stat-mini-v{font-size:20px;font-weight:800;font-family:var(–mono);}
.stat-mini-l{font-size:11px;color:var(–text2);margin-top:2px;}
.chart-title{font-size:15px;font-weight:700;margin-bottom:4px;}
.chart-sub{font-size:12px;color:var(–text2);margin-bottom:16px;}
.bar-chart{display:flex;align-items:flex-end;gap:6px;height:80px;}
.bar-col{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;}
.bar{width:100%;border-radius:6px 6px 0 0;background:var(–tint-dim);border:1px solid rgba(61,214,140,0.2);min-height:4px;}
.bar.active{background:var(–tint);}
.bar-lbl{font-size:9px;color:var(–text3);font-weight:600;}
.bar-val{font-size:9px;color:var(–text2);font-weight:600;}
.donut-wrap{display:flex;gap:20px;align-items:center;}
.donut-legend{display:flex;flex-direction:column;gap:8px;flex:1;}
.donut-item{display:flex;align-items:center;gap:8px;}
.donut-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.donut-lbl{font-size:12px;color:var(–text2);}
.donut-pct{font-size:12px;font-weight:700;margin-left:auto;}

/* ── PERSONAL RECORDS ── */
.pr-card{background:var(–card);border:1px solid var(–border);border-radius:var(–r);padding:18px;margin-bottom:14px;}
.pr-title{font-size:15px;font-weight:700;margin-bottom:14px;}
.pr-list{display:flex;flex-direction:column;gap:10px;}
.pr-row{display:flex;align-items:center;gap:12px;padding:10px 12px;background:var(–bg2);border-radius:var(–r-sm);}
.pr-ico{width:36px;height:36px;border-radius:10px;background:rgba(167,139,250,0.13);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.pr-ico svg{width:18px;height:18px;stroke:var(–purple);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.pr-name{font-size:13px;font-weight:700;flex:1;}
.pr-val{font-size:15px;font-weight:800;font-family:var(–mono);color:var(–purple);}
.pr-unit{font-size:11px;color:var(–text3);}

/* ── ACHIEVEMENTS ── */
.ach-grid{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:20px;}
.ach-card{width:calc(50% - 5px);background:var(–card);border:1px solid var(–border);border-radius:var(–r);padding:14px;display:flex;flex-direction:column;align-items:center;gap:8px;text-align:center;}
.ach-card.earned{border-color:var(–amber);background:var(–amber-dim);}
.ach-card.locked{opacity:0.4;}
.ach-ico{font-size:28px;line-height:1;}
.ach-name{font-size:13px;font-weight:700;}
.ach-desc{font-size:11px;color:var(–text2);line-height:1.4;}
.new-ach-banner{background:linear-gradient(135deg,#3d2900,#1a1500);border:1px solid var(–amber);border-radius:var(–r);padding:14px 18px;display:flex;align-items:center;gap:12px;width:100%;}
.theme-light .new-ach-banner{background:linear-gradient(135deg,#fff8e1,#fffde7);}
.new-ach-banner-ico{font-size:24px;}
.new-ach-info{flex:1;}
.new-ach-title{font-size:12px;font-weight:700;color:var(–amber);}
.new-ach-name{font-size:15px;font-weight:800;}

/* ── PROFILE / SETTINGS ── */
.settings-section{margin-bottom:24px;}
.settings-title{font-size:13px;font-weight:700;color:var(–text3);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:12px;}
.settings-row{display:flex;align-items:center;gap:14px;background:var(–card);border:1px solid var(–border);border-radius:var(–r-sm);padding:14px 16px;margin-bottom:8px;cursor:pointer;}
.settings-row:active{background:var(–card2);}
.settings-row-ico{width:34px;height:34px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.settings-row-ico svg{width:18px;height:18px;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.settings-row-label{font-size:14px;font-weight:600;flex:1;}
.settings-row-val{font-size:13px;color:var(–text2);}
.settings-row-arr svg{width:16px;height:16px;stroke:var(–text3);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.toggle-pill{width:44px;height:24px;background:var(–border);border-radius:12px;position:relative;transition:background .2s;flex-shrink:0;cursor:pointer;}
.toggle-pill.on{background:var(–tint);}
.toggle-knob{position:absolute;top:3px;left:3px;width:18px;height:18px;border-radius:50%;background:#fff;transition:transform .2s;box-shadow:0 1px 4px rgba(0,0,0,0.3);}
.toggle-pill.on .toggle-knob{transform:translateX(20px);}

/* Body weight input */
.bw-display{font-size:32px;font-weight:800;font-family:var(–mono);color:var(–tint);}
.bw-unit{font-size:14px;color:var(–text2);margin-left:4px;}
.num-pad{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:14px;}
.num-key{background:var(–card);border:1px solid var(–border);border-radius:var(–r-sm);padding:16px;font-size:20px;font-weight:700;font-family:var(–mono);cursor:pointer;text-align:center;transition:background .15s;}
.num-key:active{background:var(–card2);}
.num-key.special{font-size:14px;font-weight:600;color:var(–text2);}
.num-key.del{font-size:18px;}

/* ── HISTORY ── */
.date-hdr{padding:18px 0 8px;}
.date-t{font-size:16px;font-weight:700;}
.date-s{font-size:12px;color:var(–text3);margin-top:2px;}

/* ── SETUP ── */
.mode-toggle{display:flex;background:var(–card2);border-radius:14px;padding:4px;gap:4px;margin-bottom:20px;}
.mode-btn{flex:1;padding:10px;border-radius:11px;border:none;background:none;font-size:13px;font-weight:700;color:var(–text3);font-family:var(–font);cursor:pointer;transition:all .2s;}
.mode-btn.on{background:var(–tint);color:#000;}
.ex-grid{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px;}
.ex-chip{display:flex;align-items:center;gap:7px;padding:10px 14px;border-radius:var(–r-sm);border:1.5px solid var(–border);background:var(–card);cursor:pointer;transition:all .15s;}
.ex-chip:active{transform:scale(0.96);}
.ex-chip.sel{background:var(–tint);border-color:var(–tint);}
.ex-chip svg{width:15px;height:15px;stroke:var(–tint);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;}
.ex-chip.sel svg{stroke:#000;}
.ex-chip span{font-size:13px;font-weight:600;}
.ex-chip.sel span{color:#000;}
.custom-card{background:var(–card);border:1px solid var(–border);border-radius:var(–r);padding:18px;margin-bottom:14px;}
.custom-title{font-size:15px;font-weight:700;margin-bottom:14px;}
.custom-row{display:flex;gap:10px;margin-bottom:10px;}
.custom-field{flex:1;display:flex;flex-direction:column;gap:6px;}
.custom-label{font-size:11px;font-weight:700;color:var(–text3);text-transform:uppercase;letter-spacing:0.5px;}
.custom-ctrl{display:flex;align-items:center;background:var(–bg2);border-radius:10px;border:1px solid var(–border);overflow:hidden;}
.custom-hint{font-size:12px;color:var(–text2);line-height:1.5;margin-top:8px;padding:8px 10px;background:var(–bg2);border-radius:var(–r-sm);border:1px solid var(–border);}
.custom-type-badge{display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:700;color:var(–tint);background:var(–tint-dim);border-radius:20px;padding:4px 12px;margin-bottom:12px;}
.custom-minus,.custom-plus{background:none;border:none;color:var(–text);font-size:20px;font-weight:700;width:40px;height:40px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-family:var(–mono);}
.custom-minus:active,.custom-plus:active{background:var(–card2);}
.custom-val{flex:1;text-align:center;font-size:17px;font-weight:800;font-family:var(–mono);}

/* Notes textarea */
.notes-field{width:100%;background:var(–bg2);border:1px solid var(–border);border-radius:var(–r-sm);padding:12px;font-size:14px;font-family:var(–font);color:var(–text);resize:none;margin-top:10px;}
.notes-field::placeholder{color:var(–text3);}
.notes-field:focus{outline:none;border-color:var(–tint);}

.tips-card{background:var(–card);border:1px solid var(–border);border-radius:var(–r);padding:18px;margin-bottom:20px;}
.tips-title{font-size:12px;font-weight:700;color:var(–text3);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:12px;}
.tip-tabs{display:flex;gap:6px;margin-bottom:12px;}
.tip-tab{flex:1;padding:8px 4px;border-radius:10px;border:1.5px solid var(–border);background:none;cursor:pointer;font-size:11px;font-weight:700;color:var(–text3);font-family:var(–font);transition:all .15s;}
.tip-tab.on{border-color:var(–tint);color:var(–tint);background:var(–tint-dim);}
.tip-body ul{list-style:none;display:flex;flex-direction:column;gap:9px;}
.tip-body li{display:flex;gap:10px;align-items:flex-start;font-size:13px;color:var(–text2);line-height:1.55;}
.tip-bul{width:20px;height:20px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;}
.tip-bul.f{background:var(–blue-dim);}
.tip-bul.p{background:var(–tint-dim);}
.tip-bul.m{background:rgba(248,113,113,0.1);}
.tip-bul svg{width:11px;height:11px;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round;fill:none;}
.tip-bul.f svg{stroke:var(–blue);}
.tip-bul.p svg{stroke:var(–tint);}
.tip-bul.m svg{stroke:var(–error);}
.cat-list{display:flex;flex-direction:column;gap:10px;margin-bottom:20px;}
.cat-card{display:flex;align-items:center;gap:14px;padding:14px 16px;border-radius:var(–r);border:1.5px solid var(–border);background:var(–card);cursor:pointer;transition:all .15s;}
.cat-card:active{transform:scale(0.98);}
.cat-ico{width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:20px;}
.cat-name{font-size:15px;font-weight:700;}
.cat-desc{font-size:12px;color:var(–text2);margin-top:2px;}
.cat-arr svg{width:18px;height:18px;stroke:var(–text3);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.back-link{display:flex;align-items:center;gap:6px;background:none;border:none;color:var(–text2);font-size:13px;font-weight:600;font-family:var(–font);cursor:pointer;padding:0 0 16px 0;}
.back-link svg{width:16px;height:16px;stroke:var(–text2);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.routine-card{background:var(–card);border:1px solid var(–border);border-radius:var(–r);padding:18px;margin-bottom:14px;}
.routine-hdr{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px;}
.routine-name{font-size:16px;font-weight:800;}
.routine-sub{font-size:12px;color:var(–text2);margin-top:2px;}
.routine-badge{background:var(–tint-dim);border-radius:20px;padding:4px 10px;white-space:nowrap;}
.routine-badge span{font-size:11px;font-weight:700;color:var(–tint);}
.routine-steps{display:flex;flex-direction:column;gap:7px;margin-bottom:14px;}
.r-step{display:flex;align-items:center;gap:10px;padding:9px 12px;background:var(–bg2);border-radius:10px;}
.r-step-num{width:22px;height:22px;border-radius:7px;background:var(–tint-dim);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.r-step-num span{font-size:10px;font-weight:800;color:var(–tint);}
.r-step-name{font-size:13px;font-weight:600;}
.r-step-det{font-size:11px;color:var(–text3);margin-top:1px;}
.routine-btns{display:flex;gap:10px;}
.btn-start-now{flex:1;padding:14px;border-radius:14px;border:none;background:var(–tint);color:#000;font-size:15px;font-weight:800;font-family:var(–font);cursor:pointer;box-shadow:0 4px 20px var(–tint-glow);}
.btn-start-now:active{opacity:0.9;}
.btn-customise{padding:14px 16px;border-radius:14px;border:1.5px solid var(–border);background:none;color:var(–text2);font-size:13px;font-weight:700;font-family:var(–font);cursor:pointer;}
.btn-customise:active{background:var(–card2);}

/* ── ACTIVE / REST ── */
.feeling-check{width:100%;background:var(–card2);border:1px solid var(–border);border-radius:var(–r-sm);padding:14px;}
.feeling-check-label{font-size:10px;font-weight:700;letter-spacing:0.8px;color:var(–purple);text-transform:uppercase;margin-bottom:8px;}
.feeling-check-text{font-size:13px;color:var(–text2);line-height:1.55;}
.feeling-card{background:var(–card2);border:1px solid var(–border);border-radius:var(–r);padding:18px;width:100%;}
.feeling-card-emoji{font-size:36px;text-align:center;margin-bottom:10px;}
.feeling-card-title{font-size:16px;font-weight:800;text-align:center;margin-bottom:6px;}
.feeling-card-body{font-size:13px;color:var(–text2);line-height:1.65;text-align:center;}
.feeling-card-motivation{margin-top:12px;padding:12px;background:var(–tint-dim);border-radius:var(–r-sm);border:1px solid rgba(61,214,140,0.15);}
.feeling-card-motivation-text{font-size:13px;color:var(–tint);font-weight:600;line-height:1.5;text-align:center;}
.btn-pause{width:58px;height:58px;border-radius:var(–r);border:1.5px solid var(–border);background:var(–card);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;transition:background .15s;}
.btn-pause:active{background:var(–card2);}
.btn-pause svg{width:22px;height:22px;stroke:var(–text);fill:var(–text);stroke-width:0;stroke-linecap:round;stroke-linejoin:round;}
.btn-pause.paused{background:var(–amber-dim);border-color:var(–amber);}
.btn-pause.paused svg{stroke:var(–amber);fill:var(–amber);}
.set-row{display:flex;align-items:center;justify-content:space-between;}
.set-lbl{font-size:21px;font-weight:800;color:var(–tint);}
.elapsed{font-size:15px;color:var(–text3);font-family:var(–mono);}
.instr-card{background:var(–card);border:1px solid var(–border);border-radius:20px;padding:24px;display:flex;flex-direction:column;align-items:center;gap:14px;text-align:center;}
.instr-ico{width:52px;height:52px;border-radius:14px;background:var(–tint-dim);display:flex;align-items:center;justify-content:center;}
.instr-ico svg{width:26px;height:26px;stroke:var(–tint);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;}
.instr-txt{font-size:19px;font-weight:700;line-height:1.3;}
.rp-bar{background:var(–card);border:1px solid var(–border);border-radius:var(–r-sm);padding:12px 14px;}
.rp-lbl{font-size:11px;font-weight:700;color:var(–text3);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:8px;}
.rp-dots{display:flex;gap:5px;}
.rp-dot{flex:1;height:4px;border-radius:2px;background:var(–border);transition:background .3s;}
.rp-dot.done{background:var(–tint);}
.rp-dot.cur{background:var(–blue);}
.rest-wrap{display:flex;flex-direction:column;align-items:center;gap:16px;}
.rest-lbl{font-size:13px;font-weight:700;color:var(–text2);letter-spacing:0.5px;text-transform:uppercase;}
.rest-ring-wrap{position:relative;width:200px;height:200px;}
.rest-svg{transform:rotate(-90deg);filter:drop-shadow(0 0 12px rgba(61,214,140,0.25));}
.rest-track{fill:none;stroke:var(–card2);stroke-width:10;}
.rest-fill{fill:none;stroke:var(–tint);stroke-width:10;stroke-linecap:round;transition:stroke-dashoffset 1s linear;}
.rest-fill.urgent{stroke:var(–amber);}
.rest-fill.critical{stroke:var(–error);}
.rest-pulse{fill:none;stroke:var(–tint);stroke-width:2;opacity:0;}
.rest-pulse.urgent{stroke:var(–amber);}
.rest-pulse.critical{stroke:var(–error);}
@keyframes pulse-ring{0%{opacity:0.5;r:84;}100%{opacity:0;r:98;}}
.pulsing .rest-pulse{animation:pulse-ring 1s ease-out infinite;}
.rest-inner{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.rest-phase-lbl{font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(–tint);}
.rest-num{font-size:52px;font-weight:800;font-family:var(–mono);line-height:1;transition:transform .1s;}
.rest-num.tick{transform:scale(1.07);}
.rest-unit{font-size:13px;color:var(–text2);margin-top:4px;}
.next-lbl{font-size:13px;color:var(–text3);text-align:center;line-height:1.5;padding:0 8px;}
.sound-row{display:flex;align-items:center;gap:10px;background:var(–card);border:1px solid var(–border);border-radius:var(–r-sm);padding:10px 14px;cursor:pointer;}
.sound-row svg{width:16px;height:16px;stroke:var(–text2);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.sound-row span{font-size:13px;font-weight:600;color:var(–text2);flex:1;}

/* ── DONE ── */
.done-wrap{display:flex;flex-direction:column;align-items:center;gap:16px;text-align:center;}
.done-ico{width:90px;height:90px;border-radius:50%;background:rgba(61,214,140,0.12);display:flex;align-items:center;justify-content:center;}
.done-ico svg{width:44px;height:44px;stroke:var(–tint);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;}
.done-feeling-card{background:var(–card);border:1px solid var(–border);border-radius:var(–r);padding:16px;width:100%;text-align:left;}
.done-feeling-label{font-size:11px;font-weight:700;color:var(–tint);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:8px;}
.done-feeling-text{font-size:14px;color:var(–text2);line-height:1.65;margin-bottom:8px;}
.done-feeling-specific{font-size:13px;color:var(–text3);line-height:1.6;padding-top:8px;border-top:1px solid var(–border);}
.done-motivation-card{background:linear-gradient(135deg,#0e2318 0%,#0e1a28 100%);border:1px solid rgba(61,214,140,0.18);border-radius:var(–r);padding:16px;width:100%;text-align:left;}
.theme-light .done-motivation-card{background:linear-gradient(135deg,#e8faf0 0%,#ddeeff 100%);}
.done-motivation-text{font-size:14px;color:var(–text);line-height:1.65;font-weight:500;}
.done-streak-msg{font-size:13px;color:var(–tint);font-weight:600;margin-top:10px;padding-top:10px;border-top:1px solid rgba(61,214,140,0.2);}
.done-title{font-size:30px;font-weight:800;}
.done-sub{font-size:15px;color:var(–text2);}
.sum-grid{display:flex;flex-wrap:wrap;gap:10px;width:100%;}
.sum-card{flex:1;min-width:44%;background:var(–card);border:1px solid var(–border);border-radius:var(–r);padding:16px;display:flex;flex-direction:column;align-items:center;gap:5px;}
.sum-card.amb{background:var(–amber-dim);}
.sum-card svg{width:18px;height:18px;stroke:var(–tint);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.sum-card.amb svg{stroke:var(–amber);}
.sum-val{font-size:26px;font-weight:800;font-family:var(–mono);}
.sum-unit{font-size:11px;color:var(–text2);text-align:center;}
.pr-badge{background:rgba(167,139,250,0.15);border:1px solid rgba(167,139,250,0.3);border-radius:var(–r);padding:14px;width:100%;display:flex;align-items:center;gap:12px;}
.pr-badge-ico{font-size:22px;}
.pr-badge-txt{font-size:14px;font-weight:700;color:var(–purple);}

/* ── ONBOARDING ── */
#v-onboard{justify-content:center;align-items:center;padding:32px 28px;gap:24px;text-align:center;background:linear-gradient(160deg,#0b1a12 0%,#0b0d10 60%);overflow-y:auto;}
.ob-logo{width:80px;height:80px;border-radius:24px;background:var(–tint-dim);border:1.5px solid rgba(61,214,140,0.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.ob-logo svg{width:40px;height:40px;stroke:var(–tint);fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;}
.ob-title{font-size:30px;font-weight:800;line-height:1.2;}
.ob-title span{color:var(–tint);}
.ob-sub{font-size:15px;color:var(–text2);line-height:1.6;max-width:300px;}
.ob-levels{display:flex;flex-direction:column;gap:12px;width:100%;}
.lvl-card{display:flex;align-items:center;gap:14px;padding:16px 18px;border-radius:var(–r);border:2px solid var(–border);background:var(–card);cursor:pointer;transition:all .15s;text-align:left;}
.lvl-card:active{transform:scale(0.98);}
.lvl-card.sel{border-color:var(–tint);background:var(–tint-dim);}
.lvl-emoji{font-size:24px;width:44px;height:44px;display:flex;align-items:center;justify-content:center;background:var(–bg);border-radius:12px;flex-shrink:0;}
.lvl-info{flex:1;}
.lvl-name{font-size:15px;font-weight:700;margin-bottom:2px;}
.lvl-desc{font-size:12px;color:var(–text2);line-height:1.4;}
.lvl-chk{width:22px;height:22px;border-radius:50%;border:2px solid var(–border);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .2s;}
.lvl-card.sel .lvl-chk{background:var(–tint);border-color:var(–tint);}
.lvl-chk svg{width:12px;height:12px;stroke:#000;fill:none;stroke-width:3;stroke-linecap:round;stroke-linejoin:round;opacity:0;transition:opacity .2s;}
.lvl-card.sel .lvl-chk svg{opacity:1;}

/* ── SHEETS ── */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,0.7);display:flex;align-items:flex-end;justify-content:center;z-index:200;backdrop-filter:blur(6px);opacity:0;pointer-events:none;transition:opacity .25s;}
.overlay.show{opacity:1;pointer-events:all;}
.sheet{background:var(–card2);border:1px solid var(–border);border-radius:24px 24px 0 0;padding:28px 24px var(–bot-pad);width:100%;max-width:440px;transform:translateY(40px);transition:transform .3s cubic-bezier(.32,.72,0,1);display:flex;flex-direction:column;gap:12px;max-height:85dvh;overflow-y:auto;}
.sheet::-webkit-scrollbar{display:none;}
.overlay.show .sheet{transform:translateY(0);}
.sheet-title{font-size:18px;font-weight:800;flex-shrink:0;}
.sheet-cancel{width:100%;padding:16px;border-radius:14px;border:none;background:var(–card);color:var(–text2);font-size:16px;font-weight:700;font-family:var(–font);cursor:pointer;flex-shrink:0;}
.al-title{font-size:18px;font-weight:800;margin-bottom:8px;}
.al-msg{font-size:14px;color:var(–text2);line-height:1.55;margin-bottom:20px;}
.al-btns{display:flex;flex-direction:column;gap:10px;}
.a-btn{width:100%;padding:16px;border-radius:14px;border:none;font-size:16px;font-weight:700;font-family:var(–font);cursor:pointer;}
.a-btn:active{opacity:0.8;}
.a-btn.primary{background:var(–tint);color:#000;}
.a-btn.destructive{background:rgba(248,113,113,0.13);color:var(–error);}
.a-btn.cancel{background:var(–card);color:var(–text2);}

@keyframes fadeUp{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.fade-up{animation:fadeUp .2s ease forwards;}
@keyframes bounce-in{0%{transform:scale(0.5);opacity:0;}70%{transform:scale(1.1);}100%{transform:scale(1);opacity:1;}}
.bounce-in{animation:bounce-in .4s ease forwards;}
@keyframes confetti-fall{to{transform:translateY(110vh) rotate(720deg);opacity:0;}}
