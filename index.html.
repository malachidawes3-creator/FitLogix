function getEarnedAchs(ws,streak){return ACHIEVEMENTS.filter(a=>{try{return a.check(ws,streak);}catch{return false;}});}
function getNewAchs(ws,streak){
  const earned=new Set(JSON.parse(localStorage.getItem('wl_achs')||'[]'));
  const now=getEarnedAchs(ws,streak).map(a=>a.id);
  const newOnes=now.filter(id=>!earned.has(id));
  // Save earned dates for newly unlocked achievements
  if(newOnes.length){
    const dates=JSON.parse(localStorage.getItem('wl_ach_dates')||'{}');
    const ts=new Date().toISOString();
    newOnes.forEach(id=>{if(!dates[id])dates[id]=ts;});
    localStorage.setItem('wl_ach_dates',JSON.stringify(dates));
  }
  localStorage.setItem('wl_achs',JSON.stringify(now));
  return newOnes.map(id=>ACHIEVEMENTS.find(a=>a.id===id)).filter(Boolean);
}

