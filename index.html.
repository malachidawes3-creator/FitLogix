function checkAndUpdatePR(type,amount,unit){
  const prs=loadPRs();
  const key=type+'_'+unit;
  const prev=prs[key];
  if(!prev||amount>prev.amount){
    prs[key]={amount,unit,date:new Date().toISOString()};
    savePRs(prs);
    return{isNew:true,prev:prev?.amount,new:amount,unit,type};
  }
  return{isNew:false};
}

