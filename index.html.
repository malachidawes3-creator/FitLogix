// ── Confetti ──
function launchConfetti(){
  const canvas=document.getElementById('confetti-canvas');
  if(!canvas)return;
  const ctx=canvas.getContext('2d');
  canvas.width=canvas.offsetWidth||300;canvas.height=canvas.offsetHeight||600;
  const colors=['#3dd68c','#60a5fa','#fbbf24','#a78bfa','#f87171','#ffffff'];
  const pieces=Array.from({length:80},()=>({
    x:Math.random()*canvas.width,y:-10-Math.random()*100,
    w:6+Math.random()*8,h:8+Math.random()*6,
    color:colors[Math.floor(Math.random()*colors.length)],
    rot:Math.random()*360,rotV:(Math.random()-0.5)*8,
    vx:(Math.random()-0.5)*4,vy:2+Math.random()*4,alpha:1
  }));
  let frame=0;
  function draw(){
    ctx.clearRect(0,0,canvas.width,canvas.height);
    pieces.forEach(p=>{
      ctx.save();ctx.translate(p.x,p.y);ctx.rotate(p.rot*Math.PI/180);
      ctx.globalAlpha=p.alpha;ctx.fillStyle=p.color;
      ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);ctx.restore();
      p.x+=p.vx;p.y+=p.vy;p.rot+=p.rotV;p.vy+=0.06;
      if(frame>60)p.alpha=Math.max(0,p.alpha-0.015);
    });
    frame++;
    if(frame<160)requestAnimationFrame(draw);
    else ctx.clearRect(0,0,canvas.width,canvas.height);
  }
  requestAnimationFrame(draw);
}

