const WK='wl_w',LK='wl_l',OK='wl_ob',SK='wl_sound',BWK='wl_bw',BWU='wl_bwunit',PRK='wl_pr',TMK='wl_theme',HK='wl_height',CALGOALK='wl_calgoal';
const loadWs=()=>{try{return JSON.parse(localStorage.getItem(WK)||'[]');}catch{return[];}};
const saveWs=ws=>localStorage.setItem(WK,JSON.stringify(ws));
function addW(d){const ws=loadWs();const w={...d,id:Date.now()+Math.random().toString(36).substr(2,6),createdAt:new Date().toISOString()};ws.unshift(w);saveWs(ws);return w;}
