// ── Body changes render ──
let activeBodyEx=null;

function renderBody(){
  const el=document.getElementById('body-content');
  const ws=loadWs();

  // ── Build personalised progress section from real workout data ──
  const typeCounts={};
  const typeVolume={};
  const typeDates={};
  ws.forEach(w=>{
    typeCounts[w.type]=(typeCounts[w.type]||0)+1;
    typeVolume[w.type]=(typeVolume[w.type]||0)+(w.amount||0);
    if(!typeDates[w.type])typeDates[w.type]=[];
    typeDates[w.type].push(new Date(w.createdAt));
  });

  // Calculate days training for each type
  function getDaysSinceFirst(type){
    if(!typeDates[type]||!typeDates[type].length)return 0;
    const first=Math.min(...typeDates[type].map(d=>d.getTime()));
    return Math.round((Date.now()-first)/(1000*60*60*24));
  }

  // Match workouts to body changes entries
  const myExercises=BODY_CHANGES.filter(bc=>typeCounts[bc.type]>0)
    .sort((a,b)=>(typeCounts[b.type]||0)-(typeCounts[a.type]||0));

  // Timeline stage based on days
  function getStage(days,sessions){
    if(days<14)return{stage:0,label:'Just starting',color:'var(--text3)',pct:Math.min(100,Math.round((days/14)*20))};
    if(days<28)return{stage:1,label:'Early changes',color:'var(--amber)',pct:Math.min(100,20+Math.round(((days-14)/14)*20))};
    if(days<56)return{stage:2,label:'Visible progress',color:'var(--blue)',pct:Math.min(100,40+Math.round(((days-28)/28)*20))};
    if(days<84)return{stage:3,label:'Significant results',color:'var(--tint)',pct:Math.min(100,60+Math.round(((days-56)/28)*20))};
    if(days<180)return{stage:4,label:'Major transformation',color:'var(--tint)',pct:Math.min(100,80+Math.round(((days-84)/96)*20))};
    return{stage:5,label:'Elite level',color:'var(--tint)',pct:100};
  }

  // What changes are happening RIGHT NOW for this person
  function getCurrentChanges(bc,days){
    const tl=bc.timeline||[];
    if(days<14)return tl[0]||null;
    if(days<28)return tl[1]||tl[0]||null;
    if(days<56)return tl[2]||tl[1]||null;
    if(days<84)return tl[3]||tl[2]||null;
    if(days<180)return tl[4]||tl[3]||null;
    return tl[tl.length-1]||null;
  }

  // What's coming next
  function getNextChanges(bc,days){
    const tl=bc.timeline||[];
    if(days<14)return tl[1]||null;
    if(days<28)return tl[2]||null;
    if(days<56)return tl[3]||null;
    if(days<84)return tl[4]||null;
    return null;
  }

  let personalSection='';
  if(myExercises.length>0){
    const cards=myExercises.map(bc=>{
      const count=typeCounts[bc.type]||0;
      const days=getDaysSinceFirst(bc.type);
      const stage=getStage(days,count);
      const current=getCurrentChanges(bc,days);
      const next=getNextChanges(bc,days);
      const vol=typeVolume[bc.type]||0;
      const ex=EX.find(e=>e.type===bc.type)||EX[11];

      // Top effects happening now
      const nowEffects=(bc.effects||[]).slice(0,2);

      return`<div class="bc-progress-card fade-up">
        <div class="bc-pc-header">
          <div class="bc-pc-ico" style="background:${bc.icoColor}">
            <svg viewBox="0 0 24 24" style="stroke:${bc.icoStroke};width:20px;height:20px;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round">${IC[ex.icon]||''}</svg>
          </div>
          <div class="bc-pc-info">
            <div class="bc-pc-name">${bc.label}</div>
            <div class="bc-pc-meta">${count} session${count!==1?'s':''} · ${days} day${days!==1?'s':''} training</div>
          </div>
          <div class="bc-pc-stage" style="color:${stage.color}">${stage.label}</div>
        </div>
        <!-- Progress bar -->
        <div class="bc-pc-bar-wrap">
          <div class="bc-pc-bar-track">
            <div class="bc-pc-bar-fill" style="width:${stage.pct}%;background:${stage.color}"></div>
          </div>
          <div class="bc-pc-bar-labels">
            <span>Start</span><span>4 weeks</span><span>3 months</span><span>6 months</span>
          </div>
        </div>
        <!-- What's happening now -->
        ${current?`<div class="bc-pc-now">
          <div class="bc-pc-now-label">📍 Where you are now (${current.week})</div>
          <div class="bc-pc-now-text">${current.desc}</div>
        </div>`:''}
        <!-- Effects happening -->
        <div class="bc-pc-effects">
          ${nowEffects.map(e=>`<div class="bc-pc-effect"><span>${e.ico}</span><div><div class="bc-pc-effect-title">${e.title}</div><div class="bc-pc-effect-desc">${e.desc}</div></div></div>`).join('')}
