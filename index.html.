// ══════════════════════════════════════════════
function exportCSV(){
  if(!requirePremium('CSV export'))return;
  const ws=loadWs();
  const rows=[['Date','Time','Exercise','Type','Amount','Unit','Calories','Duration (s)','Notes']];
  ws.forEach(w=>{
    const d=new Date(w.createdAt);
    rows.push([
      d.toLocaleDateString(),d.toLocaleTimeString(),
      w.exerciseName,w.type,w.amount,w.unit,
      w.caloriesBurned||'',w.durationSeconds||'',
      w.notes||''
    ]);
  });
  const csv=rows.map(r=>r.map(c=>JSON.stringify(c)).join(',')).join('\n');
  const a=document.createElement('a');
  a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
  a.download='fitlogix.csv';
  a.click();
}

