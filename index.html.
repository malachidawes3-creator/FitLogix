let _reminderDays=JSON.parse(localStorage.getItem(‘wl_reminder_days’)||’[]’);
function toggleReminderDay(dayIdx, btn){
const i=_reminderDays.indexOf(dayIdx);
if(i>-1){
_reminderDays.splice(i,1);
btn.style.borderColor=‘var(–border)’;btn.style.background=‘var(–card)’;btn.style.color=‘var(–text2)’;
} else {
_reminderDays.push(dayIdx);
btn.style.borderColor=‘var(–tint)’;btn.style.background=‘var(–tint-dim)’;btn.style.color=‘var(–tint)’;
